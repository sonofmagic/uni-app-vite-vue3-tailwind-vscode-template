<view class="rounded-[32rpx] border border-slate-100/70 bg-white/90 p-5 shadow-[0_20px_45px_rgba(15,23,42,0.08)] data-v-e2c9ca45"><view class="flex flex-col gap-2 data-v-e2c9ca45"><view class="text-xs uppercase tracking-[6rpx] text-slate-400 data-v-e2c9ca45"> 即时体验 </view><view class="text-2xl font-semibold text-slate-900 data-v-e2c9ca45"> Tailwind 原子能力搭配 Pinia/uni-api </view></view><view class="mt-4 flex flex-col gap-4 lg:grid lg:grid-cols-3 data-v-e2c9ca45"><view class="flex flex-col gap-3 rounded-[28rpx] border border-slate-200/80 bg-gradient-to-br from-slate-900/95 to-slate-700/95 p-4 text-white shadow-xl data-v-e2c9ca45"><view class="text-xs uppercase tracking-[6rpx] text-white/60 data-v-e2c9ca45"> 动态配色按钮 </view><view class="text-3xl font-semibold data-v-e2c9ca45">{{a}}</view><view class="text-xs text-white/70 data-v-e2c9ca45"> buttonColors + computed + Pinia </view><button class="{{['w-full', 'rounded-2xl', 'py-2', 'text-base', 'font-semibold', 'shadow-lg', 'transition', 'hover:scale-[1.01]', 'data-v-e2c9ca45', b]}}" bindtap="{{c}}"> click to inc </button><view class="text-xs text-white/70 data-v-e2c9ca45"> 任意色值 `bg-[#xxx]` + hover 保留 </view><view class="test data-v-e2c9ca45"> @apply + 自定义尺寸 </view></view><view class="flex flex-col gap-3 rounded-[28rpx] border border-slate-200/80 bg-white/85 p-4 shadow-xl backdrop-blur-lg data-v-e2c9ca45"><view class="text-xs uppercase tracking-[6rpx] text-slate-500 data-v-e2c9ca45"> theme 监听 </view><view class="text-3xl font-semibold text-slate-900 data-v-e2c9ca45">{{d}}</view><view class="text-xs text-slate-500 data-v-e2c9ca45"> uni.onThemeChange -&gt; ref / computed </view><view class="mt-4 rounded-2xl border border-dashed border-slate-200 bg-slate-50/70 p-3 text-[26rpx] text-slate-600 data-v-e2c9ca45"> themeRef: {{e}}</view><view class="mt-4 data-v-e2c9ca45"><view class="text-sm font-semibold text-slate-600 data-v-e2c9ca45"> weapp-tailwindcss/css-macro </view><view class="text-xs text-slate-500 data-v-e2c9ca45"> tailwind 语法条件编译 </view><view class="mt-2 flex flex-wrap gap-2 text-xs data-v-e2c9ca45"><view class="rounded-full bg-slate-900/5 px-3 py-1 font-semibold text-slate-600 data-v-e2c9ca45" bindtap="{{f}}"> 点击复制文档 </view></view></view></view><view class="flex flex-col gap-3 rounded-[28rpx] border border-slate-200/80 bg-white/85 p-4 shadow-xl backdrop-blur-lg data-v-e2c9ca45"><view class="text-xs uppercase tracking-[6rpx] text-slate-500 data-v-e2c9ca45"> hover + group + ring </view><view class="text-sm text-slate-500 data-v-e2c9ca45"> hover-class + group-[.published] </view><view class="mt-3 flex h-16 w-32 items-center justify-center rounded-[20rpx] bg-[#389f2bb1] text-white after:content-['hover_here!'] data-v-e2c9ca45" hover-class="!bg-[gray] after:!content-['good_work!']"/><view class="text-xs text-slate-500 data-v-e2c9ca45"> pseudo + hover-class </view><view class="mt-3 text-neutral-400 data-v-e2c9ca45"> group published 示例 </view><view class="group relative rounded-2xl bg-green-200/70 p-[60px] text-xs text-slate-700 before:absolute before:left-1 before:top-1 before:text-slate-500 before:content-['父元素'] data-v-e2c9ca45" hover-class="published"><view class="rounded-xl bg-pink-400/80 p-2 text-white ring-4 ring-pink-200 group-[.published]:bg-yellow-400 group-[.published]:text-slate-800 data-v-e2c9ca45"> hover 父元素使得子元素背景变成黄色 </view></view></view></view><view class="mt-5 flex flex-col gap-4 md:grid md:grid-cols-2 data-v-e2c9ca45"><view class="rounded-[26rpx] border border-slate-200/80 bg-white/70 p-4 shadow-inner data-v-e2c9ca45"><view class="text-sm font-semibold text-slate-700 data-v-e2c9ca45"> Tailwind ring + 自定义按钮 </view><view class="text-xs text-slate-500 data-v-e2c9ca45"> ring utilities </view><view class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 data-v-e2c9ca45"><view class="w-full rounded-md bg-pink-500 py-2 text-center font-semibold text-white ring-4 ring-pink-300 data-v-e2c9ca45"> Default Ring </view><button class="btn data-v-e2c9ca45"> @layer 定制按钮 </button></view></view><view class="rounded-[26rpx] border border-slate-200/80 bg-white/70 p-4 shadow-inner data-v-e2c9ca45"><view class="text-sm font-semibold text-slate-700 data-v-e2c9ca45"> Pro tips </view><view class="text-xs text-slate-500 data-v-e2c9ca45"> 结合 Icon、伪元素、Grid </view><view class="mt-3 space-y-2 data-v-e2c9ca45"><view qa:for="{{g}}" qa:for-item="tip" qa:key="c" class="rounded-2xl border border-slate-100/80 bg-slate-50/60 px-3 py-2 text-[26rpx] text-slate-600 data-v-e2c9ca45"><view class="font-semibold text-slate-700 data-v-e2c9ca45">{{tip.a}}</view><view class="text-slate-500 data-v-e2c9ca45">{{tip.b}}</view></view></view><view class="mt-4 text-neutral-600 underline data-v-e2c9ca45" bindtap="{{h}}"> Grid布局 + Icon 方案（点击复制链接） </view></view></view></view>