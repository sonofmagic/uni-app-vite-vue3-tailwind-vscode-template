<view class="rounded-[32rpx] border border-slate-100/70 bg-white/90 p-5 shadow-[0_20px_45px_rgba(15,23,42,0.08)]"><view class="text-xs uppercase tracking-[6rpx] text-slate-400"> 渐变 & 玻璃 </view><view class="text-2xl font-semibold text-slate-900"> 自由的视觉语言 </view><view class="mt-4 flex flex-col gap-4 md:grid md:grid-cols-3"><view qa:for="{{a}}" qa:for-item="item" qa:key="c" class="{{['rounded-[28rpx]', 'p-4', 'shadow-lg', item.d]}}"><view class="text-xl font-semibold">{{item.a}}</view><view class="text-xs opacity-80">{{item.b}}</view></view></view><view class="mt-5 text-sm text-slate-500"> feature cards </view><view class="mt-3 flex flex-col gap-4 md:grid md:grid-cols-2"><view qa:for="{{b}}" qa:for-item="feature" qa:key="f" class="{{['rounded-[28rpx]', 'border', 'border-slate-100/80', 'bg-gradient-to-br', 'p-4', 'shadow-lg', feature.g]}}"><view class="flex items-center gap-3"><text class="{{['text-[36px]', feature.a, feature.b]}}"/><view class="text-lg font-semibold text-slate-800">{{feature.c}}</view></view><view class="mt-1 text-xs text-slate-500">{{feature.d}}</view><view class="mt-3 inline-flex rounded-full bg-white/70 px-3 py-1 text-xs font-semibold text-slate-600">{{feature.e}}</view></view></view></view>